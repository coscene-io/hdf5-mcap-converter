  <!-- Joint connecting world to Arm 2 Base -->
  <joint name="world_to_arm2_base" type="fixed">
    <parent link="world" />
    <child link="arm2_base_link" />
    <origin xyz="0 -0.4 0" rpy="0 0 0" />
  </joint>

  <!-- Arm 2 Joints -->
  <joint name="arm2_waist" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="10" lower="-3.14158" upper="3.14158" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0 0 0.079" />
    <parent link="arm2_base_link" />
    <child link="arm2_shoulder_link" />
    <dynamics friction="0.1" />
