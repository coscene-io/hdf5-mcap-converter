  <!-- Joint connecting world to Arm 1 Base -->
  <joint name="world_to_arm1_base" type="fixed">
    <parent link="world" />
    <child link="arm1_base_link" />
    <origin xyz="0 0.4 0" rpy="0 0 0" />
  </joint>

  <!-- Arm 1 Joints -->
  <joint name="arm1_waist" type="revolute">
    <axis xyz="0 0 1" />
    <limit effort="10" lower="-3.14158" upper="3.14158" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0 0 0.079" />
    <parent link="arm1_base_link" />
    <child link="arm1_shoulder_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_shoulder" type="revolute">
    <axis xyz="0 1 0" />
    <limit effort="20" lower="-1.85005" upper="1.25664" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0 0 0.04805" />
    <parent link="arm1_shoulder_link" />
    <child link="arm1_upper_arm_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_elbow" type="revolute">
    <axis xyz="0 1 0" />
    <limit effort="15" lower="-1.76278" upper="1.60570" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0.05955 0 0.3" />
    <parent link="arm1_upper_arm_link" />
    <child link="arm1_upper_forearm_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_forearm_roll" type="revolute">
    <axis xyz="1 0 0" />
    <limit effort="2" lower="-3.14158" upper="3.14158" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0.2 0 0" />
    <parent link="arm1_upper_forearm_link" />
    <child link="arm1_lower_forearm_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_wrist_angle" type="revolute">
    <axis xyz="0 1 0" />
    <limit effort="5" lower="-1.86750" upper="2.23402" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0.1 0 0" />
    <parent link="arm1_lower_forearm_link" />
    <child link="arm1_wrist_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_wrist_rotate" type="revolute">
    <axis xyz="1 0 0" />
    <limit effort="1" lower="-3.14158" upper="3.14158" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0.069744 0 0" />
    <parent link="arm1_wrist_link" />
    <child link="arm1_gripper_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_ee_arm" type="fixed">
    <axis xyz="1 0 0" />
    <origin rpy="0 0 0" xyz="0.042825 0 0" />
    <parent link="arm1_gripper_link" />
    <child link="arm1_ee_arm_link" />
  </joint>
  <joint name="arm1_gripper" type="continuous">
    <axis xyz="1 0 0" />
    <limit effort="1" velocity="3.14159" />
    <origin rpy="0 0 0" xyz="0.005675 0 0" />
    <parent link="arm1_ee_arm_link" />
    <child link="arm1_gripper_prop_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_gripper_bar" type="fixed">
    <axis xyz="1 0 0" />
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="arm1_ee_arm_link" />
    <child link="arm1_gripper_bar_link" />
  </joint>
  <joint name="arm1_ee_bar" type="fixed">
    <axis xyz="1 0 0" />
    <origin rpy="0 0 0" xyz="0.025875 0 0" />
    <parent link="arm1_gripper_bar_link" />
    <child link="arm1_fingers_link" />
  </joint>
  <joint name="arm1_left_finger" type="prismatic">
    <axis xyz="0 1 0" />
    <limit effort="5" lower="0.021" upper="0.057" velocity="1" />
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="arm1_fingers_link" />
    <child link="arm1_left_finger_link" />
    <dynamics friction="0.1" />
  </joint>
  <joint name="arm1_right_finger" type="prismatic">
    <axis xyz="0 1 0" />
    <limit effort="5" lower="-0.057" upper="-0.021" velocity="1" />
    <origin rpy="0 0 0" xyz="0 0 0" />
    <parent link="arm1_fingers_link" />
    <child link="arm1_right_finger_link" />
    <dynamics friction="0.1" />
    <mimic joint="arm1_left_finger" multiplier="-1" offset="0" />
  </joint>
  <joint name="arm1_ee_gripper" type="fixed">
    <axis xyz="1 0 0" />
    <origin rpy="0 0 0" xyz="0.0385 0 0" />
    <parent link="arm1_fingers_link" />
    <child link="arm1_ee_gripper_link" />
  </joint>


